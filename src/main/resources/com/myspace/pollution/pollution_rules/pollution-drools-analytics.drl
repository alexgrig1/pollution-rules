rule "Drools shift PM10 humidity risk - room2 afternoon"
when
    $pm10Avg : Number() from accumulate(
        SensorReading(locationId == "room2", shift == "afternoon", pm10 != null, $v : pm10);
        average($v)
    )

    $humidityAvg : Number() from accumulate(
        SensorReading(locationId == "room2", shift == "afternoon", humidity != null, $h : humidity);
        average($h)
    )

    $count : Number() from accumulate(
        SensorReading(locationId == "room2", shift == "afternoon", pm10 != null);
        count(1)
    )

    eval($count.intValue() >= 10 && $pm10Avg.doubleValue() > 70.0 && $humidityAvg.doubleValue() > 65.0)
then
    PollutionAnalytic analytic = new PollutionAnalytic();
    analytic.setType("DROOLS_SHIFT_PM10_HUMIDITY_RISK");
    analytic.setPeriodType("shift");
    analytic.setPollutant("pm10_humidity");
    analytic.setLocationId("room2");
    analytic.setValue($pm10Avg.doubleValue());
    analytic.setThreshold(70.0);
    analytic.setCountUsed($count.intValue());
    analytic.setShift("afternoon");
    analytic.setMessage("Drools calculated PM10/humidity risk for room2 afternoon. PM10 avg="
        + $pm10Avg.doubleValue()
        + ", humidity avg=" + $humidityAvg.doubleValue()
        + ", count=" + $count.intValue());
    analytic.setTs(new Date());
    insert(analytic);
end


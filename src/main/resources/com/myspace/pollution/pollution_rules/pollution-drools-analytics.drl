package com.myspace.pollution.pollution_rules

import com.myspace.pollution.pollution_rules.SensorReading
import com.myspace.pollution.pollution_rules.PollutionAnalytic
import java.util.Date

rule "Drools aggregate room1 morning PM25"
when
    $avg : Number() from accumulate(
        SensorReading(
            locationId == "room1",
            shift == "morning",
            pm25 != null,
            $v : pm25
        );
        average($v)
    )

    $count : Number() from accumulate(
        SensorReading(
            locationId == "room1",
            shift == "morning",
            pm25 != null
        );
        count(1)
    )

    eval($count.intValue() >= 10 && $avg.doubleValue() > 40.0)
then
    PollutionAnalytic analytic = new PollutionAnalytic();
    analytic.setType("DROOLS_SHIFT_MORNING_PM25_AVG");
    analytic.setPeriodType("shift");
    analytic.setPollutant("pm25");
    analytic.setLocationId("room1");
    analytic.setValue($avg.doubleValue());
    analytic.setThreshold(40.0);
    analytic.setCountUsed($count.intValue());
    analytic.setShift("morning");
    analytic.setMessage("Drools calculated morning PM2.5 average for room1. Avg="
        + $avg.doubleValue()
        + ", count=" + $count.intValue());
    analytic.setTs(new Date());
    insert(analytic);
end

rule "Drools aggregate room2 afternoon PM10 humidity risk"
when
    $pm10Avg : Number() from accumulate(
        SensorReading(
            locationId == "room2",
            shift == "afternoon",
            pm10 != null,
            $v : pm10
        );
        average($v)
    )

    $humidityAvg : Number() from accumulate(
        SensorReading(
            locationId == "room2",
            shift == "afternoon",
            humidity != null,
            $h : humidity
        );
        average($h)
    )

    $count : Number() from accumulate(
        SensorReading(
            locationId == "room2",
            shift == "afternoon",
            pm10 != null
        );
        count(1)
    )

    eval($count.intValue() >= 10 && $pm10Avg.doubleValue() > 70.0 && $humidityAvg.doubleValue() > 65.0)
then
    PollutionAnalytic analytic = new PollutionAnalytic();
    analytic.setType("DROOLS_SHIFT_PM10_HUMIDITY_RISK");
    analytic.setPeriodType("shift");
    analytic.setPollutant("pm10_humidity");
    analytic.setLocationId("room2");
    analytic.setValue($pm10Avg.doubleValue());
    analytic.setThreshold(70.0);
    analytic.setCountUsed($count.intValue());
    analytic.setShift("afternoon");
    analytic.setMessage("Drools calculated PM10/humidity risk for room2 afternoon. PM10 avg="
        + $pm10Avg.doubleValue()
        + ", humidity avg=" + $humidityAvg.doubleValue()
        + ", count=" + $count.intValue());
    analytic.setTs(new Date());
    insert(analytic);
end

rule "Drools aggregate outdoor monthly PM10"
when
    $avg : Number() from accumulate(
        SensorReading(
            locationId == "outdoor_south",
            pm10 != null,
            $v : pm10
        );
        average($v)
    )

    $count : Number() from accumulate(
        SensorReading(
            locationId == "outdoor_south",
            pm10 != null
        );
        count(1)
    )

    eval($count.intValue() >= 10 && $avg.doubleValue() > 80.0)
then
    PollutionAnalytic analytic = new PollutionAnalytic();
    analytic.setType("DROOLS_MONTHLY_PM10_AVG");
    analytic.setPeriodType("monthly");
    analytic.setPollutant("pm10");
    analytic.setLocationId("outdoor_south");
    analytic.setValue($avg.doubleValue());
    analytic.setThreshold(80.0);
    analytic.setCountUsed($count.intValue());
    analytic.setMessage("Drools calculated monthly PM10 average for outdoor_south. Avg="
        + $avg.doubleValue()
        + ", count=" + $count.intValue());
    analytic.setTs(new Date());
    insert(analytic);
end
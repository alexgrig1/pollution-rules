package com.myspace.pollution.pollution_rules

import com.myspace.pollution.pollution_rules.PollutionAggregate
import com.myspace.pollution.pollution_rules.PollutionAnalytic
import java.util.Date

rule "Scheduled hourly PM2.5 analytic high"
when
    $a : PollutionAggregate(
        periodType == "hourly",
        pollutant == "pm25",
        avgValue != null,
        countUsed != null,
        countUsed >= 10,
        avgValue > 50.0
    )
then
    PollutionAnalytic analytic = new PollutionAnalytic();
    analytic.setType("HOURLY_PM25_AVG");
    analytic.setPeriodType("hourly");
    analytic.setPollutant("pm25");
    analytic.setLocationId($a.getLocationId());
    analytic.setValue($a.getAvgValue());
    analytic.setThreshold(50.0);
    analytic.setCountUsed($a.getCountUsed());
    analytic.setHourOfDay($a.getHourOfDay());
    analytic.setDayOfWeek($a.getDayOfWeek());
    analytic.setMonthOfYear($a.getMonthOfYear());
    analytic.setMessage("Scheduled hourly PM2.5 average calculated by Drools. Avg="
        + $a.getAvgValue()
        + ", count=" + $a.getCountUsed()
        + ", location=" + $a.getLocationId());
    analytic.setTs(new Date());
    insert(analytic);

 
end


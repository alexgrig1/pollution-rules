package com.myspace.pollution.pollution_rules;

com.myspace.pollution.pollution_rules.Alert( )com.myspace.pollution.pollution_rules.SensorReading( )com.myspace.pollution.pollution_rules.Alert( )com.myspace.pollution.pollution_rules.SensorReading( )package com.myspace.pollution.pollution_rules

import com.myspace.pollution.pollution_rules.SensorReading
import com.myspace.pollution.pollution_rules.Alert
import java.util.Date

rule "PM2.5 threshold alert"
when
    $r : SensorReading( pm25 != null, pm25 > 50.0 )
then
    Alert a = new Alert();
    a.setType("PM25_HIGH");
    a.setMessage("PM2.5 high: " + $r.getPm25() + " at location " + $r.getLocationId());
    a.setTs(new Date());
    insert(a);
end